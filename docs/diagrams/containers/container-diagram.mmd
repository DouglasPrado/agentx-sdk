    style ToolExec fill:#438dd5,stroke:#2e6295,color:#fff
    style MemMgr fill:#438dd5,stroke:#2e6295,color:#fff
    style KnowMgr fill:#438dd5,stroke:#2e6295,color:#fff
    style SkillMgr fill:#438dd5,stroke:#2e6295,color:#fff
    style MCPAdapt fill:#438dd5,stroke:#2e6295,color:#fff
    style SQLiteDB fill:#438dd5,stroke:#2e6295,color:#fff
