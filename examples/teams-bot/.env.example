# Microsoft Bot Framework — from Azure Bot registration or Bot Framework Portal
MICROSOFT_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_APP_PASSWORD=your-app-password-here
# Optional: leave empty for multi-tenant
MICROSOFT_APP_TENANT_ID=

# Server port (default 3978)
PORT=3978

# OpenRouter — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Agent model (optional, defaults to claude-sonnet)
# AGENT_MODEL=anthropic/claude-sonnet-4-20250514

# Tavily web search (optional)
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# MCP Albert (optional)
# MCP_ALBERT_URL=https://mcp.example.com/mcp
# MCP_ALBERT_TOKEN=your-token-here
